<div style="max-width: 450px; margin: 50px auto; background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
  <h2 style="margin-top: 0; color: #2c3e50; text-align: center;">Create an Account</h2>
  
  <%= form_with model: @user, url: signup_path, local: true, style: "display: flex; flex-direction: column; gap: 15px; margin-top: 20px;" do |f| %>
    <% if @user.errors.any? %>
      <div style="background: #f8d7da; color: #721c24; padding: 10px; border-radius: 4px; font-size: 0.85rem;">
        <ul style="margin: 0; padding-left: 15px;">
          <% @user.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "Your Full Name", style: "display: block; font-weight: bold; margin-bottom: 5px; font-size: 0.9rem;" %>
      <%= f.text_field :name, style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;" %>
    </div>
    <div>
      <%= f.label :email, "Email Address", style: "display: block; font-weight: bold; margin-bottom: 5px; font-size: 0.9rem;" %>
      <%= f.email_field :email, style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;" %>
    </div>
    <div>
      <%= f.label :password, "Password", style: "display: block; font-weight: bold; margin-bottom: 5px; font-size: 0.9rem;" %>
      <%= f.password_field :password, style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;" %>
    </div>
    <div>
      <%= f.label :password_confirmation, "Confirm Your Password", style: "display: block; font-weight: bold; margin-bottom: 5px; font-size: 0.9rem;" %>
      <%= f.password_field :password_confirmation, style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;" %>
    </div>
    <%= f.submit "Register Account", style: "background: #3498db; color: white; padding: 10px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; margin-top: 10px;" %>
  <% end %>
</div>