<div style="background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 30px;">
  <span style="background: #3498db; color: white; font-size: 0.8rem; padding: 4px 10px; border-radius: 12px; font-weight: bold;"><%= @event.category.name %></span>
  
  <h1 style="color: #2c3e50; margin: 15px 0 10px 0;"><%= @event.title %></h1>
  <p style="color: #718096; font-size: 0.95rem; margin-bottom: 20px;">
    📍 <strong>Location:</strong> <%= @event.location %> &nbsp;|&nbsp; 
    📆 <strong>Date:</strong> <%= @event.date.strftime("%B %d, %Y at %I:%M %p") %> &nbsp;|&nbsp; 
    👤 <strong>Organizer:</strong> <%= @event.user.name %>
  </p>

  <hr style="border: 0; border-top: 1px solid #edf2f7; margin-bottom: 20px;">

  <h3 style="color: #4a5568;">Event Description</h3>
  <p style="color: #2d3748; line-height: 1.6; font-size: 1.1rem; white-space: pre-line;"><%= @event.description %></p>

  <div style="margin-top: 30px; padding: 20px; background: #f7fafc; border-radius: 6px; display: flex; justify-content: space-between; align-items: center;">
    <div>
      <h4 style="margin: 0; color: #4a5568;">Attendance Registration Status</h4>
      <p style="margin: 5px 0 0 0; font-size: 0.9rem; color: #718096;"><%= @event.registrations.count %> community member(s) attending.</p>
    </div>
    
    <div>
      <% if logged_in? %>
        <% if @current_user_registration %>
          <%= button_to "Cancel My Registration", event_registration_path(@event, @current_user_registration), method: :delete, style: "background: #e74c3c; color: white; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;" %>
        <% else %>
          <%= button_to "Register for this Event", event_registrations_path(@event), method: :post, style: "background: #2ecc71; color: white; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;" %>
        <% end %>
      <% else %>
        <a href="<%= login_path %>" style="color: #3498db; text-decoration: none; font-weight: bold; font-size: 0.95rem;">Log in to register for this event &rarr;</a>
      <% end %>
    </div>
  </div>

  <% if logged_in? && (@event.user == current_user || current_user.admin?) %>
    <div style="margin-top: 25px; padding-top: 20px; border-top: 1px solid #edf2f7; display: flex; gap: 15px;">
      <%= link_to "Edit Event Information", edit_event_path(@event), style: "background: #f39c12; color: white; padding: 8px 15px; text-decoration: none; border-radius: 4px; font-size: 0.9rem;" %>
      <%= button_to "Cancel and Delete Event", event_path(@event), method: :delete, data: { confirm: "Are you sure?" }, style: "background: #c0392b; color: white; padding: 8px 15px; border: none; border-radius: 4px; cursor: pointer; font-size: 0.9rem;" %>
    </div>
  <% end %>
</div>

<div style="background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
  <h3 style="margin-top: 0; margin-bottom: 20px; color: #2c3e50;">Event Discussion</h3>

  <% if logged_in? %>
    <%= form_with model: [@event, @comment], local: true, style: "margin-bottom: 30px;" do |f| %>
      <div style="margin-bottom: 12px;">
        <%= f.text_area :content, placeholder: "Ask a question or leave a note about this event...", rows: 3, style: "width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; font-family: inherit;" %>
      </div>
      <%= f.submit "Post Comment", style: "background: #2c3e50; color: white; padding: 8px 15px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;" %>
    <% end %>
  <% else %>
    <p style="background: #f7fafc; padding: 15px; border-radius: 4px; font-size: 0.9rem; color: #718096;"><a href="<%= login_path %>" style="color: #3498db; text-decoration: none; font-weight: bold;">Log in</a> to join the community event discussion.</p>
  <% end %>

  <div style="display: flex; flex-direction: column; gap: 15px;">
    <% if @event.comments.select(&:persisted?).any? %>
      <% @event.comments.select(&:persisted?).each do |c| %>
        <div style="background: #f7fafc; padding: 15px; border-radius: 6px; border-left: 4px solid #cbd5e0;">
          <p style="margin: 0 0 5px 0; font-size: 0.9rem; color: #4a5568;"><strong><%= c.user.name %></strong> <span style="color: #a0aec0; font-size: 0.8rem; margin-left: 10px;"><%= c.created_at.strftime("%b %d, %Y at %I:%M %p") %></span></p>
          <p style="margin: 0; color: #2d3748; line-height: 1.4;"><%= c.content %></p>
        </div>
      <% end %>
    <% else %>
      <p style="color: #a0aec0; font-style: italic; margin: 0;">No comments written yet.</p>
    <% end %>
  </div>
</div>